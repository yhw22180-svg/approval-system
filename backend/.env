# === 데이터베이스 설정 ===
# SQLite (기본값 - 설치 없이 바로 사용 가능)
DATABASE_URL=sqlite:///./approval_system.db

# MySQL 사용 시 아래 주석 해제 후 위 줄 주석 처리
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/approval_db

# PostgreSQL 사용 시
# DATABASE_URL=postgresql://username:password@localhost:5432/approval_db

# === JWT 보안 키 ===
# 반드시 복잡한 랜덤 문자열로 변경하세요!
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === 이메일 설정 (Gmail SMTP) ===
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true

# === 파일 업로드 설정 ===
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# === CORS 설정 (프론트엔드 주소) ===
FRONTEND_URL=http://localhost:3000

# === 회사 정보 ===
COMPANY_NAME=우리회사
